{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": false,
    "moduleResolution": "node",
    "allowJs": true
  },
  "include": ["scripts/**/*", "src/**/*"],
  "exclude": ["node_modules"]
}
